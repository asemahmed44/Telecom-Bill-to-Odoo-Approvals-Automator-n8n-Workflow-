    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst phoneData = $('🚦 Product Found?').item.json;\nconst sd = $getWorkflowStaticData('global');\nconst approvalId = response?.id || response?.result;\nif (!approvalId || typeof approvalId !== 'number') {\n  const e = sd.errors || []; e.push({ phone: phoneData.phone_number, error: JSON.stringify(response) }); sd.errors = e;\n  return [{ json: { _error: true, phone: phoneData.phone_number } }];\n}\nconst ids = sd.approvalIds || []; ids.push({ id: approvalId, phone: phoneData.phone_number, amount: phoneData.amount }); sd.approvalIds = ids;\nreturn [{ json: { approvalId, phone: phoneData.phone_number, amount: phoneData.amount } }];"
