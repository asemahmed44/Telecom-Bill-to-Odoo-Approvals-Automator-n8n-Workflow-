      "parameters": {
        "jsCode": "const sd = $getWorkflowStaticData('global');\nconst loopItem = $('🔄 Loop Per Phone').item.json;\nconst phoneNumber = loopItem.phone_number;\nconst amount = loopItem.amount;\nconst allItems = $input.all();\nconst products = allItems.map(i => i.json).filter(p => p && p.id && typeof p.id === 'number');\nif (!products || products.length === 0) {\n  const m = sd.missingProducts || []; m.push({ phone: phoneNumber, amount }); sd.missingProducts = m;\n  return [{ json: { _skip: true, phone: phoneNumber } }];\n}\nconst product = products[0];\nreturn [{ json: { _skip: false, phone_number: phoneNumber, amount, product_id: product.id, approval_name: 'Telephone Bill - ' + phoneNumber + ' - April 2026' } }];"
